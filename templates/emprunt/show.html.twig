{% extends 'base.html.twig' %}

{% block title %}Emprunt{% endblock %}

{% block body %}
    <div class="container">
        <div class="container containerform">
            <form class="login-form" method="post">
                <h1>Emprunts</h1>

                <table class="table">
                    <tbody>
                        <tr>
                            <th>Id</th>
                            <td>{{ emprunt.id }}</td>
                        </tr>
                        <tr>
                            <th>DateEmprunt</th>
                            <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('Y-m-d H:i:s') : '' }}</td>
                        </tr>
                        <tr>
                            <th>DateRetour</th>
                            <td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('Y-m-d H:i:s') : '' }}</td>
                        </tr>
                        <tr>
                            <th>Statut</th>
                            <td>{{ emprunt.statut }}</td>
                        </tr>
                        <tr>
                            <th>Book_id</th>
                            <td>{{ emprunt.bookId }}</td>
                        </tr>
                        <tr>
                            <th>User_id</th>
                            <td>{{ emprunt.userId }}</td>
                        </tr>
                    </tbody>
                </table>

                <a href="{{ path('app_emprunt_index') }}" class="btn btn-secondary mt-4">Revenir à la liste</a>

                <a href="{{ path('app_emprunt_edit', {'id': emprunt.id}) }}" class="btn btn-primary mt-4">Modifier</a>

                {{ include('emprunt/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
