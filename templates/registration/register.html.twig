{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <div class="container">
        <div class="container containerform">
            <form class="login-form" method="post">
                <h1>Register</h1>

                {{ form_errors(registrationForm) }}

                {{ form_start(registrationForm) }}
                    
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control form mt3', 'placeholder':'email'}}) }}
                    {{ form_widget(registrationForm.firstname, {'attr': {'class': 'form-control form mt3', 'placeholder':'firstname'}}) }}
                    {{ form_widget(registrationForm.lastname, {'attr': {'class': 'form-control form mt3', 'placeholder':'lastname'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {
                        label: 'Password', 'attr': {'class': 'form-control', 'placeholder':'Mot de passe'}}) }}
                   
                    {{ form_row(registrationForm.agreeTerms) }}

                    <button type="submit" class="btn">Register</button>
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>  
{% endblock %}
