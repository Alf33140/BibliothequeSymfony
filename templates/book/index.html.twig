{% extends 'base.html.twig' %}

{% block title %}Book index{% endblock %}

{% block body %}
    <div class="container">
            <div class="container containerform">
                <form class="login-form" method="post">
                    <h1>Book index</h1>

                    <table class="table">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Titre</th>
                                <th>Auteur</th>
                                <th>Isbn</th>
                                <th>Stock</th>
                                <th>actions</th>
                            </tr>
                        </thead>
                        <tbody>


                        {% for book in books %}
                            <tr>
                                <td>{{ book.id }}</td>
                                <td>{{ book.Titre }}</td>
                                <td>{{ book.auteur }}</td>
                                <td>{{ book.isbn }}</td>
                                <td>{{ book.stock }}</td>
                                <td>
                                    <a href="{{ path('app_book_show', {'id': book.id}) }}"  class="btn btn-primary mt-4">show</a>
                                    <a href="{{ path('app_book_edit', {'id': book.id}) }}"  class="btn btn-secondary mt-4">modifier</a>
                                    <a href="{{ path('app_book_new', {'id': book.id}) }}"  class="btn btn-secondary mt-4">nouveau</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6">no records found</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>

                    <a href="{{ path('app_book_new') }}">Create new</a>
                </div>
            </div>
    </div>
{% endblock %}
